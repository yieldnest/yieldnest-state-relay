# RPC URLs: copy to `.env` and prefer a provider with an API key.
#
# Fork tests (`StateRelayFork*`) call `vm.createSelectFork` and read contract storage.
# Free/public endpoints often rate-limit, return HTML/proxy errors, or drop mid-request;
# Forge then fails with e.g. "failed to get storage", "upstream connect error", or
# "cannot parse json-rpc response".
#
# Examples (replace YOUR_KEY): Alchemy, Infura, QuickNode, Ankr (with key), etc.
ETH_MAINNET_RPC=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
ARBITRUM_RPC=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
 