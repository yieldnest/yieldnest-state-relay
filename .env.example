# RPC URLs: copy to `.env` and prefer a provider with an API key.
#
# Fork tests (`StateRelayFork*`) read contract storage from a live chain.
# Mainnet is supplied via `forge test --rpc-url <URL>`; the multi-fork test additionally reads `ARBITRUM_RPC` below.
# Free/public endpoints often rate-limit, return HTML/proxy errors, or drop mid-request;
# Forge then fails with e.g. "failed to get storage", "upstream connect error", or
# "cannot parse json-rpc response".
#
# Examples (replace YOUR_KEY): Alchemy, Infura, QuickNode, Ankr (with key), etc.
ARBITRUM_RPC=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY

# Deploy/configure scripts: must match relay input `.owner` (Anvil default dev key → 0xf39F…).
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# `forge script --rpc-url` targets (chain id 1 vs 42161). For two local Anvils, override per session:
# RPC_MAINNET=http://127.0.0.1:8545
# RPC_ARBITRUM=http://127.0.0.1:8546
# Or point at providers: RPC_MAINNET=<mainnet provider URL>, RPC_ARBITRUM=$ARBITRUM_RPC
